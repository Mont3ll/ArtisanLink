# ===========================================
# ArtisanLink Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# -------------------------------------------
# DATABASE
# -------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development: postgresql://artisan_user:artisan_password@localhost:5432/artisanlink_db
# For production: Use your managed database URL (e.g., from Supabase, Neon, Railway)
DATABASE_URL="postgresql://artisan_user:artisan_password@localhost:5432/artisanlink_db"

# -------------------------------------------
# CLERK AUTHENTICATION
# -------------------------------------------
# Get these from https://dashboard.clerk.com
# Required for user authentication

# Publishable key (safe to expose to browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Secret key (never expose to browser)
CLERK_SECRET_KEY=sk_test_your_key_here

# Auth redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/after-sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/after-sign-up

# -------------------------------------------
# M-PESA DARAJA API (Safaricom)
# -------------------------------------------
# Get these from https://developer.safaricom.co.ke
# Required for payment processing in Kenya

# Consumer credentials from Safaricom Developer Portal
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret

# Lipa Na M-Pesa Online (STK Push) credentials
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORT_CODE=your_mpesa_short_code

# Callback URL for payment notifications (must be publicly accessible)
# Use ngrok or similar for local development: https://your-ngrok-url.ngrok.io/api/payments/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback

# Environment: 'sandbox' for testing, 'production' for live
MPESA_ENVIRONMENT=sandbox

# -------------------------------------------
# APPLICATION SETTINGS
# -------------------------------------------
# Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for signing tokens/sessions (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# Logging level: 'debug', 'info', 'warn', 'error'
# Development: 'debug'
# Production: 'info' or 'warn'
LOG_LEVEL=info

# -------------------------------------------
# FILE UPLOAD (Cloudinary)
# -------------------------------------------
# Optional: For portfolio images and profile pictures
# Get these from https://cloudinary.com/console

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Maximum upload size in bytes (default: 5MB)
MAX_UPLOAD_SIZE=5242880

# -------------------------------------------
# EMAIL SERVICE (Optional)
# -------------------------------------------
# For sending notifications and password resets
# Configure with your SMTP provider (Gmail, SendGrid, etc.)

EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_email@gmail.com
EMAIL_SERVER_PASSWORD=your_app_password

# From address for outgoing emails
EMAIL_FROM=noreply@artisanlink.co.ke

# -------------------------------------------
# FEATURE FLAGS (Optional)
# -------------------------------------------
# Enable/disable features during development

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# Enable SMS notifications via Africa's Talking
ENABLE_SMS_NOTIFICATIONS=false

# Enable M-Pesa payments
ENABLE_MPESA_PAYMENTS=false

# -------------------------------------------
# AFRICA'S TALKING (Optional)
# -------------------------------------------
# For SMS notifications
# Get these from https://account.africastalking.com

AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=ArtisanLink

# -------------------------------------------
# MAPBOX (For Map Visualization)
# -------------------------------------------
# Required for artisan location maps
# Get your access token from https://account.mapbox.com/access-tokens/

# Public access token (safe to expose to browser)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# -------------------------------------------
# MONITORING & ANALYTICS (Optional)
# -------------------------------------------
# Error tracking and performance monitoring

# Sentry DSN for error tracking
# Get from https://sentry.io
SENTRY_DSN=

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -------------------------------------------
# RATE LIMITING (Optional)
# -------------------------------------------
# Configure API rate limits

# Requests per minute for authenticated users
RATE_LIMIT_AUTHENTICATED=100

# Requests per minute for anonymous users
RATE_LIMIT_ANONYMOUS=20

# -------------------------------------------
# CRON JOBS
# -------------------------------------------
# Secret key for authenticating cron job requests
# Generate with: openssl rand -base64 32
# Used by /api/cron/* endpoints
CRON_SECRET=your_cron_secret_here

# -------------------------------------------
# ADMIN SETUP (Development Only)
# -------------------------------------------
# Secret key for promoting the first admin user
# Generate with: openssl rand -base64 32
# IMPORTANT: Remove or leave empty in production after first admin is created
# Only works when no admins exist in the database
ADMIN_PROMOTION_SECRET=

# -------------------------------------------
# SEED TEST USERS (Development Only)
# -------------------------------------------
# Clerk User IDs for test accounts that link to seeded database data
# 
# Setup Instructions:
# 1. Go to Clerk Dashboard -> Users -> Create User
# 2. Create 3 users with these emails and set their publicMetadata:
#    - admin@artisanlink.co.ke   -> publicMetadata: { "role": "admin" }
#    - client@artisanlink.co.ke  -> publicMetadata: { "role": "client" }
#    - artisan@artisanlink.co.ke -> publicMetadata: { "role": "artisan" }
# 3. Copy each user's Clerk ID (format: user_xxxxx) and paste below
# 4. Run: npm run db:reset
#
# Leave empty to use placeholder IDs (won't work for actual login)
SEED_ADMIN_CLERK_ID=
SEED_CLIENT_CLERK_ID=
SEED_ARTISAN_CLERK_ID=

# -------------------------------------------
# M-PESA B2C (Business to Customer) - Artisan Payouts
# -------------------------------------------
# Required for automatic artisan payout functionality
# Get these from https://developer.safaricom.co.ke

# B2C Short code (different from STK Push shortcode)
MPESA_B2C_SHORTCODE=600000

# Initiator credentials (set up in M-Pesa portal)
MPESA_B2C_INITIATOR_NAME=testapi
MPESA_B2C_INITIATOR_PASSWORD=your_initiator_password

# B2C callback URLs (must be publicly accessible)
MPESA_B2C_RESULT_URL=https://yourdomain.com/api/payments/b2c/result
MPESA_B2C_TIMEOUT_URL=https://yourdomain.com/api/payments/b2c/timeout

# Safaricom certificate for encrypting security credentials
# Either provide the certificate content (with \n for newlines)
# Or place the .cer file in lib/mpesa/certificates/
# Sandbox: sandbox.cer, Production: production.cer
MPESA_B2C_CERTIFICATE=

# Enable B2C payouts (set to 'true' to enable)
ENABLE_B2C_PAYOUTS=false

# -------------------------------------------
# PAYMENT COMMISSION SETTINGS
# -------------------------------------------
# Platform commission configuration

# Standard commission rate (default: 10%)
PLATFORM_COMMISSION_RATE=0.10

# Promotional commission rate for new artisans (default: 5%)
PROMOTIONAL_COMMISSION_RATE=0.05

# Number of jobs qualifying for promotional rate (default: 5)
PROMOTIONAL_JOB_COUNT=5

# Percentage of deposit paid immediately to artisan (default: 80%)
# Remaining is held as escrow until job completion
ARTISAN_DEPOSIT_SHARE=0.80

# Minimum payout amount in KES (default: 10)
MINIMUM_PAYOUT_AMOUNT=10

# Maximum retry attempts for failed payouts (default: 3)
PAYOUT_MAX_RETRIES=3

# Batch size for payout processing cron job (default: 10)
PAYOUT_BATCH_SIZE=10

# Admin email for payout failure notifications
PAYOUT_ADMIN_EMAIL=admin@artisanlink.co.ke
