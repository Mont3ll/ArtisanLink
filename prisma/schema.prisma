// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  CLIENT
  ARTISAN
  ADMIN
}

enum UserStatus {
  PENDING // Email not verified
  ACTIVE // Email verified and active
  SUSPENDED // Temporarily suspended
  BANNED // Permanently banned
}

enum ArtisanStatus {
  PENDING // Application pending review
  VERIFIED // Certificate verified
  REJECTED // Application rejected
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  CARD
  BANK_TRANSFER
  CASH // Cash payment (used during testing phase)
}

// Core User Model
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique // Clerk user ID
  email     String     @unique
  firstName String
  lastName  String
  phone     String?
  role      UserRole   @default(CLIENT)
  status    UserStatus @default(PENDING)

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?

  // Relationships
  profile              Profile?
  sentMessages         Message[]      @relation("MessageSender")
  receivedMessages     Message[]      @relation("MessageReceiver")
  clientConversations  Conversation[] @relation("ClientConversations")
  artisanConversations Conversation[] @relation("ArtisanConversations")
  reviews              Review[]       @relation("ClientReviews")
  savedArtisans        SavedArtisan[]
  searchHistory        SearchHistory[]
  notifications        Notification[]
  notificationPreferences NotificationPreferences?

  // Job relationships (Phase 9)
  clientJobs  Job[] @relation("ClientJobs")
  artisanJobs Job[] @relation("ArtisanJobs")

  // Payout relationships (Phase 11)
  payouts          ArtisanPayout[] @relation("ArtisanPayouts")
  completedJobCount Int            @default(0) // For promotional commission tracking

  // Indexes for common queries
  @@index([role, status]) // Filter users by role and status
  @@index([createdAt]) // Sort users by creation date
  @@index([email]) // Email lookups (in addition to unique)
  @@map("users")
}

// Extended Profile Information
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Information
  bio          String?
  profileImage String? // URL to profile image
  coverImage   String? // URL to cover image
  website      String?

  // Location Information (for map display)
  latitude  Float?
  longitude Float?
  address   String?
  city      String?
  county    String?
  country   String  @default("Kenya")

  // Artisan-specific fields
  profession    String? // Required for artisans
  experience    Int? // Years of experience
  hourlyRate    Float? // Hourly rate in KES
  isAvailable   Boolean        @default(false) // Toggle for map visibility
  artisanStatus ArtisanStatus?

  // Capacity Management (Phase 9)
  maxConcurrentJobs Int     @default(5)  // Maximum jobs artisan can handle
  currentJobCount   Int     @default(0)  // Current active jobs
  autoToggleAvailability Boolean @default(true) // Auto-toggle availability when at capacity

  // Certificate and verification
  certificateUrl        String? // URL to uploaded certificate
  certificateUploadedAt DateTime?
  verifiedAt            DateTime?
  verifiedBy            String? // Admin user ID who verified

  // ID Document Verification (Phase 10)
  idDocumentUrl         String?         // URL to uploaded ID document
  idDocumentType        IdDocumentType? // Type of ID document
  idDocumentUploadedAt  DateTime?
  rejectionReason       String?         // Detailed reason if rejected
  resubmissionCount     Int             @default(0) // Track verification attempts
  verificationNotes     String?         // Admin internal notes

  // Ratings and reviews
  averageRating Float @default(0.0)
  totalReviews  Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  portfolioItems       PortfolioItem[]
  subscription         Subscription?
  reviews              Review[]
  specializations      Specialization[]
  savedBy              SavedArtisan[]
  verificationHistory  VerificationHistory[]

  // Indexes for common queries
  @@index([userId]) // User lookup
  @@index([profession]) // Filter by profession
  @@index([county]) // Filter by county
  @@index([city]) // Filter by city
  @@index([artisanStatus]) // Filter by verification status
  @@index([isAvailable]) // Filter available artisans
  @@index([averageRating]) // Sort by rating
  @@index([hourlyRate]) // Sort/filter by rate
  @@index([latitude, longitude]) // Geospatial queries
  @@index([createdAt]) // Sort by creation date
  @@map("profiles")
}

// Portfolio/Work Items for Artisans
model PortfolioItem {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title       String
  description String?
  imageUrl    String // Main image URL
  imageUrls   String[] // Additional images
  category    String? // e.g., "Woodworking", "Metalwork"
  tags        String[] // Searchable tags

  // Project details
  completedAt DateTime?
  duration    String? // e.g., "2 weeks"
  cost        Float? // Project cost in KES

  // Visibility
  isPublic   Boolean @default(true)
  isFeatured Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for common queries
  @@index([profileId]) // Filter by artisan profile
  @@index([category]) // Filter by category
  @@index([isPublic, isFeatured]) // Public and featured items
  @@index([createdAt]) // Sort by creation date
  @@map("portfolio_items")
}

// Artisan Specializations/Skills
model Specialization {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name       String
  category   String? // Main category
  skillLevel Int     @default(1) // 1-5 skill level
  yearsExp   Int? // Years of experience in this skill

  createdAt DateTime @default(now())

  // Indexes for common queries
  @@index([profileId]) // Filter by profile
  @@index([category]) // Filter by category
  @@index([name]) // Search by name
  @@unique([profileId, name])
  @@map("specializations")
}

// Subscription Management
model Subscription {
  id        String  @id @default(cuid())
  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan
  status SubscriptionStatus @default(INACTIVE)

  // Billing Information
  startDate DateTime
  endDate   DateTime
  amount    Float // Amount in KES
  currency  String   @default("KES")

  // M-Pesa Information
  mpesaRequestId     String?
  mpesaCheckoutId    String?
  mpesaTransactionId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  payments Payment[]

  // Indexes for common queries
  @@index([profileId]) // Filter by profile
  @@index([status]) // Filter by status
  @@index([endDate]) // Find expiring subscriptions
  @@index([status, endDate]) // Find active subscriptions expiring soon
  @@map("subscriptions")
}

// Payment Tracking
model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount   Float
  currency String        @default("KES")
  method   PaymentMethod
  status   PaymentStatus @default(PENDING)

  // M-Pesa specific fields
  mpesaRequestId     String?
  mpesaCheckoutId    String?
  mpesaTransactionId String?
  mpesaReceiptNumber String?
  phoneNumber        String?

  // Metadata
  description   String?
  failureReason String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  // Indexes for common queries
  @@index([subscriptionId]) // Filter by subscription
  @@index([status]) // Filter by status
  @@index([mpesaCheckoutId]) // M-Pesa callback lookup
  @@index([createdAt]) // Sort by creation date
  @@map("payments")
}

// Messaging System
model Conversation {
  id        String @id @default(cuid())
  clientId  String
  artisanId String

  client  User @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  artisan User @relation("ArtisanConversations", fields: [artisanId], references: [id], onDelete: Cascade)

  status  ConversationStatus @default(ACTIVE)
  subject String?

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime?

  // Relationships
  messages Message[]
  jobs     Job[]     // Jobs created from this conversation (Phase 9)

  // Indexes for common queries
  @@index([clientId]) // Client's conversations
  @@index([artisanId]) // Artisan's conversations
  @@index([status]) // Filter by status
  @@index([lastMessageAt]) // Sort by recent activity
  @@unique([clientId, artisanId])
  @@map("conversations")
}

model Message {
  id             String @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  content String
  status  MessageStatus @default(SENT)

  // File attachments
  attachmentUrls String[]

  // Timestamps
  createdAt DateTime  @default(now())
  readAt    DateTime?

  // Indexes for common queries
  @@index([conversationId]) // Messages in conversation
  @@index([senderId]) // Sent messages
  @@index([receiverId]) // Received messages
  @@index([receiverId, status]) // Unread messages for receiver
  @@index([createdAt]) // Sort by creation date
  @@map("messages")
}

// Reviews and Ratings
model Review {
  id        String @id @default(cuid())
  profileId String // Artisan being reviewed
  clientId  String // Client leaving the review

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  client  User    @relation("ClientReviews", fields: [clientId], references: [id], onDelete: Cascade)

  rating  Int // 1-5 stars
  comment String?

  // Project details
  projectTitle String?
  projectCost  Float?

  // Moderation
  isApproved Boolean @default(false)
  isHidden   Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for common queries
  @@index([profileId]) // Reviews for artisan
  @@index([clientId]) // Reviews by client
  @@index([rating]) // Filter by rating
  @@index([isApproved, isHidden]) // Moderation filtering
  @@index([createdAt]) // Sort by creation date
  @@unique([profileId, clientId])
  @@map("reviews")
}

// Saved Artisans (Client Favorites)
model SavedArtisan {
  id        String   @id @default(cuid())
  userId    String   // Client who saved
  profileId String   // Artisan profile saved

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Indexes for common queries
  @@index([userId]) // User's saved artisans
  @@index([profileId]) // Who saved this artisan
  @@unique([userId, profileId])
  @@map("saved_artisans")
}

// Admin Activity Logs
model ActivityLog {
  id String @id @default(cuid())

  // Actor information
  adminId    String
  adminEmail String

  // Action details
  action     String // e.g., "USER_VERIFIED", "SUBSCRIPTION_UPDATED"
  targetType String // e.g., "USER", "SUBSCRIPTION", "PAYMENT"
  targetId   String

  // Context
  description String?
  metadata    Json? // Additional data about the action
  ipAddress   String?
  userAgent   String?

  // Timestamps
  createdAt DateTime @default(now())

  // Indexes for common queries
  @@index([adminId]) // Filter by admin
  @@index([action]) // Filter by action type
  @@index([targetType, targetId]) // Find logs for specific entity
  @@index([createdAt]) // Sort by creation date
  @@map("activity_logs")
}

// System Settings
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json

  description String?
  isPublic    Boolean @default(false) // Can be accessed by frontend

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Search History for Clients
model SearchHistory {
  id     String @id @default(cuid())
  userId String

  // Search parameters
  query      String? // Text search query
  profession String? // Profession filter
  location   String? // Location/county filter
  minRating  Float?  // Minimum rating filter
  maxRadius  Float?  // Distance radius in km
  filters    Json?   // Additional filters as JSON

  // Results info
  resultCount Int?

  // Geo information (if location-based search)
  latitude  Float?
  longitude Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("search_history")
}

// Notification Types
enum NotificationType {
  MESSAGE       // New message received
  REVIEW        // New review received
  VERIFICATION  // Profile verification status change
  SYSTEM        // System announcements
  PROMOTION     // Promotional notifications
  BOOKING       // Booking/inquiry notifications
  JOB           // Job request, quote, status changes (Phase 9)
  PAYMENT       // Payment notifications (Phase 9)
}

// Notifications System
model Notification {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  title   String
  message String
  data    Json?   // Additional context data (e.g., artisanId, messageId, etc.)
  isRead  Boolean @default(false)

  // Link to related entity
  linkUrl String? // URL to navigate to when clicked

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Notification Preferences
model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Notification channels
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  smsNotifications   Boolean @default(false)

  // Notification types
  messageNotifications      Boolean @default(true)  // New messages
  reviewNotifications       Boolean @default(true)  // New reviews
  verificationNotifications Boolean @default(true)  // Profile verification updates
  systemNotifications       Boolean @default(true)  // System announcements
  promotionNotifications    Boolean @default(false) // Marketing/promotions
  bookingNotifications      Boolean @default(true)  // Booking/inquiry updates

  // Quiet hours
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? // Format: "HH:mm" (e.g., "22:00")
  quietHoursEnd     String? // Format: "HH:mm" (e.g., "08:00")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}

// ============================================================================
// Phase 9: Job Request & Booking System
// ============================================================================

// Job Status Enum
enum JobStatus {
  REQUESTED     // Client sent request
  QUOTED        // Artisan sent quote
  ACCEPTED      // Both parties agreed
  DEPOSIT_PAID  // Client paid deposit
  IN_PROGRESS   // Work started
  COMPLETED     // Work finished
  PAID          // Final payment made
  CANCELLED     // Either party cancelled
  DECLINED      // Artisan declined
  DISPUTED      // Payment or work dispute
}

// Quote Status Enum
enum QuoteStatus {
  DRAFT              // Artisan drafting quote
  SENT               // Quote sent to client
  ACCEPTED           // Client accepted quote
  REVISION_REQUESTED // Client requested revision (round 1 only)
  DECLINED           // Client declined quote (final)
  EXPIRED            // Quote validity expired
}

// Job Payment Type Enum
enum JobPaymentType {
  DEPOSIT       // Initial deposit payment
  FINAL         // Final payment on completion
  MILESTONE     // Milestone payment (future)
  REFUND        // Refund to client
}

// Job Model
model Job {
  id String @id @default(cuid())

  // Participants
  clientId  String
  artisanId String
  client    User @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  artisan   User @relation("ArtisanJobs", fields: [artisanId], references: [id], onDelete: Cascade)

  // Optional link to conversation where job was created
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Job Details
  title       String
  description String
  category    String?
  location    String? // Where the work will be done

  // Pricing
  clientBudget Float?  // Client's proposed budget
  agreedPrice  Float?  // Final agreed price (from accepted quote)
  depositAmount Float? // Calculated deposit amount
  depositPercent Float @default(30) // Deposit percentage (default 30%)

  // Scheduling
  requestedStartDate DateTime? // When client wants work to start
  requestedEndDate   DateTime? // Client's deadline
  scheduledStartDate DateTime? // Agreed start date
  scheduledEndDate   DateTime? // Agreed end date
  startedAt          DateTime? // When work actually started
  completedAt        DateTime? // When work was completed

  // Payment tracking (convenience fields derived from payments)
  depositPaid        Boolean   @default(false)
  depositPaidAt      DateTime?
  finalPaid          Boolean   @default(false)
  finalPaidAt        DateTime?

  // Escrow tracking (Phase 11)
  heldAmount      Float?    // Amount held from deposit (20%)
  heldReleasedAt  DateTime? // When held amount was released

  // Status
  status         JobStatus @default(REQUESTED)
  declineReason  String?   // Reason if artisan declined
  cancelReason   String?   // Reason if cancelled
  cancelledBy    String?   // UserId of who cancelled

  // Completion
  completionNotes String?  // Notes from artisan on completion
  clientFeedback  String?  // Feedback from client

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  quotes      Quote[]
  payments    JobPayment[]
  payouts     ArtisanPayout[]
  earnings    PlatformEarning[]

  // Indexes for common queries
  @@index([clientId])
  @@index([artisanId])
  @@index([status])
  @@index([conversationId])
  @@index([createdAt])
  @@index([artisanId, status])
  @@index([clientId, status])
  @@map("jobs")
}

// Quote Model
model Quote {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Quote Details
  amount      Float   // Quoted price (total)
  description String? // What's included
  notes       String? // Additional notes

  // Scheduling
  estimatedStartDate DateTime?
  estimatedEndDate   DateTime?
  estimatedDuration  String? // e.g., "2 weeks", "3 days"

  // Terms
  validUntil         DateTime? // Quote expiry date
  paymentTerms       String?   // Payment terms description
  materialsIncluded  Boolean   @default(false)
  materialsCost      Float?    // Separate materials cost if not included

  // Deposit negotiation - artisan can request different deposit %
  requestedDepositPercent Float? // Artisan's requested deposit percentage (10-80%)

  // Status
  status   QuoteStatus @default(DRAFT)
  isDraft  Boolean     @default(true) // true = draft, false = final
  round    Int         @default(1) // 1 = first quote, 2 = final quote

  // Response
  clientResponse String?   // Client's response/feedback
  respondedAt    DateTime? // When client responded

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sentAt    DateTime? // When quote was sent to client

  // Relationships
  lineItems QuoteLineItem[]

  // Indexes
  @@index([jobId])
  @@index([status])
  @@index([jobId, round])
  @@map("quotes")
}

// Quote Line Item Model - Itemized breakdown for transparency
model QuoteLineItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Item Details
  category    String  // LABOR, MATERIALS, EQUIPMENT, TRANSPORT, CONSUMABLES, OPERATION_COST, OTHER, DISCOUNT, MISCELLANEOUS
  name        String  // e.g., "Skilled Labor", "PVC Pipes", "Scaffolding Rental"
  description String? // Optional details

  // Pricing
  quantity  Float  @default(1)
  unit      String? // e.g., "hours", "pieces", "days", "trips"
  unitPrice Float   // Price per unit in KES
  total     Float   // quantity × unitPrice (can be negative for discounts)

  // Metadata
  isSystemGenerated Boolean @default(false) // True for auto-added Discount/Miscellaneous
  sortOrder         Int     @default(0)

  createdAt DateTime @default(now())

  @@index([quoteId])
  @@index([category])
  @@map("quote_line_items")
}

// Job Payment Model
model JobPayment {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Payment Details
  type     JobPaymentType
  amount   Float
  currency String         @default("KES")
  status   PaymentStatus  @default(PENDING)

  // M-Pesa specific fields
  mpesaRequestId     String?
  mpesaCheckoutId    String?
  mpesaTransactionId String?
  mpesaReceiptNumber String?
  phoneNumber        String?

  // Metadata
  description   String?
  failureReason String?

  // For refunds
  refundReason  String?
  refundedAt    DateTime?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  // Indexes
  @@index([jobId])
  @@index([status])
  @@index([type])
  @@index([mpesaCheckoutId])
  @@index([createdAt])
  @@map("job_payments")
}

// ============================================================================
// Phase 11: B2C Artisan Payouts
// ============================================================================

// Payout Status Enum
enum PayoutStatus {
  PENDING           // Awaiting hourly batch processing
  PROCESSING        // B2C request sent, awaiting callback
  COMPLETED         // Successfully paid to artisan
  FAILED            // B2C failed after all retries
  CANCELLED         // Cancelled before processing
}

// Payout Type Enum
enum PayoutType {
  DEPOSIT_SHARE     // 80% of deposit sent to artisan
  FINAL_PAYMENT     // Final payment minus commission
  REFUND            // Refund to artisan
  ADJUSTMENT        // Manual adjustment by admin
}

// Artisan Payout Model - Tracks money sent to artisans via M-Pesa B2C
model ArtisanPayout {
  id        String @id @default(cuid())
  artisanId String
  artisan   User   @relation("ArtisanPayouts", fields: [artisanId], references: [id], onDelete: Cascade)

  // Link to job (optional - could be adjustment, etc.)
  jobId String?
  job   Job?   @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Payout Details
  type        PayoutType
  grossAmount Float        // Amount before any deductions
  commission  Float        // Commission deducted (0 for deposit share)
  netAmount   Float        // Amount sent to artisan
  currency    String       @default("KES")

  // Artisan phone (snapshot at time of payout creation)
  phoneNumber String

  // M-Pesa B2C fields
  mpesaConversationId   String?  // M-Pesa conversation ID
  mpesaOriginatorId     String?  // Our internal tracking ID
  mpesaTransactionId    String?  // M-Pesa transaction ID on success
  mpesaReceiptNumber    String?  // M-Pesa receipt number

  // Status & Retry
  status           PayoutStatus @default(PENDING)
  failureReason    String?
  resultCode       Int?         // M-Pesa result code
  resultDesc       String?      // M-Pesa result description
  retryCount       Int          @default(0)
  maxRetries       Int          @default(3)
  nextRetryAt      DateTime?

  // Admin intervention
  requiresManualReview Boolean   @default(false)
  adminNotes           String?
  reviewedBy           String?   // Admin user ID
  reviewedAt           DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime? // When B2C was initiated
  completedAt DateTime? // When B2C succeeded

  @@index([artisanId])
  @@index([jobId])
  @@index([status])
  @@index([status, nextRetryAt]) // For batch processing query
  @@index([createdAt])
  @@index([mpesaConversationId])
  @@map("artisan_payouts")
}

// Platform Earnings Model - Tracks commission earned by the platform
model PlatformEarning {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  artisanId String // Denormalized for easy querying

  // Earning Details
  jobValue         Float   // Total job value
  commissionRate   Float   // Rate applied (0.05 or 0.10)
  commissionAmount Float   // Actual commission earned
  isPromotional    Boolean @default(false) // Was promotional rate applied?

  // Source payment type
  paymentType String // "DEPOSIT" or "FINAL"

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([artisanId])
  @@index([createdAt])
  @@map("platform_earnings")
}

// ============================================================================
// Phase 10: Enhanced Verification System
// ============================================================================

// ID Document Type Enum
enum IdDocumentType {
  NATIONAL_ID
  PASSPORT
  DRIVING_LICENSE
  ALIEN_ID
}

// Verification History Model (tracks all verification attempts)
model VerificationHistory {
  id        String @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Submission details
  certificateUrl  String?
  idDocumentUrl   String?
  idDocumentType  IdDocumentType?

  // Decision
  status          ArtisanStatus
  processedBy     String?        // Admin user ID
  processedAt     DateTime?
  rejectionReason String?
  adminNotes      String?        // Internal notes

  // Timestamps
  submittedAt DateTime @default(now())

  @@index([profileId])
  @@index([status])
  @@map("verification_history")
}

// Artisan Invite Model (admin sends invites to join as artisans)
model ArtisanInvite {
  id        String @id @default(cuid())
  token     String @unique @default(cuid())

  // Recipient info
  email     String
  name      String?
  phone     String?

  // Invite metadata
  message   String? // Personal note from admin
  invitedBy String  // Admin user ID
  
  // Status tracking
  status    InviteStatus @default(PENDING)
  usedAt    DateTime?
  usedByUserId String? // User ID if invite was accepted

  // Timestamps
  createdAt DateTime @default(now())
  expiresAt DateTime // Invite link expires

  @@index([email])
  @@index([token])
  @@index([status])
  @@index([invitedBy])
  @@map("artisan_invites")
}

enum InviteStatus {
  PENDING  // Invite sent, not used
  ACCEPTED // Invite was used to sign up
  EXPIRED  // Invite link expired
  REVOKED  // Admin revoked the invite
}
